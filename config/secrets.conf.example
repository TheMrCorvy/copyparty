# =============================================================================
# secrets.conf.example — Template for Untracked User Credentials
# =============================================================================
# Copy this file to config/secrets.conf and add your actual user accounts.
# Do NOT commit secrets.conf to git (it is added to .gitignore).
#
# Syntax:
#   [accounts]
#   username_or_email: password
# =============================================================================

[accounts]
# Define your admin account (needed to access the private external drive 3)
admin: adminpass123

# Define the new user's email/username and password here
newuser@example.com: userpassword123
