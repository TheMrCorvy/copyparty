# =============================================================================
# .env — Environment Variables for copyparty Docker setup
# =============================================================================
# Copy this file and edit values for each deployment environment.
#
#   Windows (testing):   copy .env.example .env   → edit paths to Windows style
#   macOS (homelab):     cp  .env.example .env    → edit paths to Unix style
#   Ubuntu (future):     cp  .env.example .env    → edit paths to Unix style
#
# IMPORTANT: Never commit your real .env to version control!
# =============================================================================

# ── Web UI port exposed on the host ──────────────────────────────────────────
# Change this if the port is already taken by another service.
COPYPARTY_PORT=3923

# ── Timezone for correct log timestamps ──────────────────────────────────────
# Examples: America/New_York | America/Argentina/Buenos_Aires | Europe/London
TZ=America/New_York

# ── Config directory (where copyparty.conf lives) ────────────────────────────
# Windows example:  CONFIG_PATH=C:/Users/gonza/OneDrive/Desktop/localhost/copyparty/config
# macOS example:    CONFIG_PATH=/Users/gonza/homelab/copyparty/config
# Ubuntu example:   CONFIG_PATH=/opt/copyparty/config
CONFIG_PATH=./config

# ── Drive paths — HOST filesystem paths (outside Docker) ─────────────────────
#
# WINDOWS 11 (testing on your PC):
#   Use forward slashes. Docker Desktop on Windows translates these.
#   Example:
#     MAIN_DRIVE_PATH=C:/Users/gonza/Documents
#     EXT_DRIVE1_PATH=D:/
#     EXT_DRIVE2_PATH=E:/
#
# macOS (Mac Mini homelab):
#   Example:
#     MAIN_DRIVE_PATH=/Volumes/Macintosh HD/Users/Shared
#     EXT_DRIVE1_PATH=/Volumes/ExternalDrive1
#     EXT_DRIVE2_PATH=/Volumes/ExternalDrive2
#
# Ubuntu Server (future migration):
#   Drives are typically mounted under /mnt or /media
#   Example:
#     MAIN_DRIVE_PATH=/mnt/main
#     EXT_DRIVE1_PATH=/mnt/external1
#     EXT_DRIVE2_PATH=/mnt/external2
#
# ─── FILL IN YOUR ACTUAL PATHS BELOW ─────────────────────────────────────────
MAIN_DRIVE_PATH=C:/Users/gonza/Documents
EXT_DRIVE1_PATH=D:/
EXT_DRIVE2_PATH=E:/

# ── Resource limits ───────────────────────────────────────────────────────────
# Tune these for your host machine:
#   Mac Mini i5 with many apps running → conservative defaults are fine.
#   Increase memory if you index very large libraries (e.g., 512M or 1G).
CPU_LIMIT=0.50
MEM_LIMIT=256M
